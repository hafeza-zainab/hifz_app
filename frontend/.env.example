# Frontend Environment Variables
# Copy this file to .env and fill in all values before starting the frontend.
# NEVER commit .env to version control.

# ─── API Configuration ───────────────────────────────────────────────────────────
# Backend API URL (adjust if backend is hosted elsewhere)
REACT_APP_API_URL=http://localhost:5000

# ─── Feature Flags ────────────────────────────────────────────────────────────────
# Enable/disable features (true/false)
REACT_APP_ENABLE_COACH=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_TOUR=true

# ─── Development ───────────────────────────────────────────────────────────────────
# Enable detailed logging in development (true/false)
REACT_APP_DEBUG=false
